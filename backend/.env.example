APP_NAME=sentinel
ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:devpass@localhost:5432/sentinel

# generate real values with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=replace-me
JWT_SECRET=replace-me-differently

# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
